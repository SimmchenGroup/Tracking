                   % emphasize displacement along                     
                d_1 = (p2(:,1) - p1(1))*cos(p1(5)) - (p2(:,2) - p1(2))*sin(p1(5));
                d_2 = (p2(:,1) - p1(1))*sin(p1(5)) + (p2(:,2) - p1(2))*cos(p1(5));%×ø±êÏµ±ä»»
                dis = d_1.*d_1 + d_2.*d_2*4;
                    
% Tracking Condition                                        
