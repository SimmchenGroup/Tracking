                        % if ture,find the right one
                        % update RawResults(AllStartIndex(SearchTime)
                        tk = AllStartIndex(SearchTime) + tt-1;
                        RawResults(tk,7) = TrajNum;
                        % update the output
                        PointerForTr = PointerForTr + 1;
                        tr(PointerForTr,:) = RawResults(tk,:);
                        % update SearchTime
                        SearchTime = SearchTime + 1;
                        % update p1
                        p1 = RawResults(tk,:);                        
                        % reset missing step
                        if MissingSteps > 0
                            MissingSteps = 0;
                        end
                    elseif (length(tt) > 1)
                        % choose the minimal distance
                        [Y kk] = min(dis(tt));                        
                        tk = AllStartIndex(SearchTime) + tt(kk(1)) -1;
                        % update RawResults(AllStartIndex(SearchTime)
                        RawResults(tk,7) = TrajNum;
                        % update the output
                        PointerForTr = PointerForTr + 1;
                        tr(PointerForTr,:) = RawResults(tk,:);                        
                        % update SearchTime
                        SearchTime = SearchTime + 1;                        
                        % update p1
                        p1 = RawResults(tk,:);                        
                        % reset missing step
                        if MissingSteps > 0
                            MissingSteps = 0;
                        end
                    else
                        % no finding
                        MissingSteps = MissingSteps + 1;
                        if MissingSteps < LostSteps
                            % update SearchTime
                            SearchTime = SearchTime + 1; 
                        else                        
                            StopSearch = 1;                            
                        end
                    end
             end
       end
    end
end

